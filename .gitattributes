# Keep line endings correct per platform, whatever OS you clone on.
* text=auto eol=lf

# Linux shell scripts and systemd units must stay LF
*.sh    text eol=lf
*.service text eol=lf

# Python is fine either way; keep it LF for consistency
*.py    text eol=lf

# Windows scripts must be CRLF or PowerShell/cmd can misbehave
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary
*.ico   binary
*.png   binary
